mtllib ./vp.mtl

v -0.5 0 0
v 0.5 0 0
v -0.5 0 -1
v 0.5 0 -1

v -0.5 1 0
v 0.5 1 0
v -0.5 1 -1
v 0.5 1 -1

vn 0 1 0
vn 1 0 0
vn -1 0 0
vn 0 -1 0
vn 0 0 -1
vn 0 0 1

g white
usemtl white
# top
f 7//4 8//4 5//4
f 5//4 8//4 6//4

usemtl mirror
# front
f 2//5 1//5 6//5
f 6//5 1//5 5//5

# back
f 3//6 4//6 7//6
f 7//6 4//6 8//6

usemtl red_2
# left
f 1//2 3//2 5//2
f 5//2 3//2 7//2

usemtl floor
# bottom
f 1//1 2//1 3//1
f 3//1 2//1 4//1

g right
usemtl blue_2
# right
f 4//3 2//3 8//3
f 8//3 2//3 6//3
